# ── Gerenciador de Guichê — variáveis de ambiente ─────────────────────────────
# Copie este arquivo para .env e ajuste os valores antes de subir com Docker.
# O arquivo .env NÃO deve ser commitado no repositório.

# Senha do banco de dados PostgreSQL
POSTGRES_PASSWORD=guiche_secret

# Porta do host para acessar a aplicação (http://localhost:APP_PORT)
APP_PORT=3000

# Segredo para assinatura de sessões — TROQUE em produção
SESSION_SECRET=troque_em_producao
